{
    "name": "Reclaim your time",
    "description": "Your big brother who does not allow you to waste time",
    "version": "1.0",
    "manifest_version": 3,
    "background": {
        "service_worker": "background.js"
      },
    "permissions": ["storage", "activeTab", "scripting","tabs"],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "/images/rush16.png",
            "32": "/images/rush32.png",
            "48": "/images/rush48.png",
            "128": "/images/rush128.png"
          }
    },
    "icons": {
        "16": "/images/rush16.png",
        "32": "/images/rush32.png",
        "48": "/images/rush48.png",
        "128": "/images/rush128.png"
      }
  }